{# Standalone ZMK keymap - no Miryoku dependency #}
// Generated by switchboard - do not edit directly
// Self-contained: no Miryoku includes needed

#include <behaviors.dtsi>
#include <behaviors/mouse_keys.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/rgb.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/ext_power.h>
#include <dt-bindings/zmk/pointing.h>

// ── macros ──────────────────────────────────────────────────────────────
#define U_MT(MOD, TAP) &u_mt MOD TAP
#define U_LT(LAYER, TAP) &u_lt LAYER TAP
#define U_NP &none
#define U_NA &none
#define U_NU &none

// clipboard (win)
#define U_RDO &kp LC(Y)
#define U_PST &kp LC(V)
#define U_CPY &kp LC(C)
#define U_CUT &kp LC(X)
#define U_UND &kp LC(Z)

// shift functions
#define U_RGB_TOG &rgb_ug RGB_TOG
#define U_RGB_EFF &rgb_ug RGB_EFF
#define U_RGB_HUI &rgb_ug RGB_HUI
#define U_RGB_SAI &rgb_ug RGB_SAI
#define U_RGB_BRI &rgb_ug RGB_BRI
#define U_EP_TOG &ext_power EP_TOG
#define U_BOOT &bootloader

// mouse keys
#define U_BTN1 &mkp MB1
#define U_BTN2 &mkp MB2
#define U_BTN3 &mkp MB3
#define U_MS_D &mmv MOVE_DOWN
#define U_MS_L &mmv MOVE_LEFT
#define U_MS_R &mmv MOVE_RIGHT
#define U_MS_U &mmv MOVE_UP
#define U_WH_D &msc SCRL_DOWN
#define U_WH_L &msc SCRL_LEFT
#define U_WH_R &msc SCRL_RIGHT
#define U_WH_U &msc SCRL_UP

// ── layer indices ───────────────────────────────────────────────────────
#define U_BASE   0
#define U_EXTRA  1
#define U_TAP    2
#define U_BUTTON 3
#define U_NAV    4
#define U_MOUSE  5
#define U_MEDIA  6
#define U_NUM    7
#define U_SYM    8
#define U_FUN    9

// ── layer macros (one per layer, defines the physical layout) ──────────
{% for layer in layers %}#define SWITCHBOARD_MAP_{{ layer.name | upper }}( \
     K00, K01, K02, K03, K04,                K05, K06, K07, K08, K09, \
     K10, K11, K12, K13, K14,                K15, K16, K17, K18, K19, \
     K20, K21, K22, K23, K24,                K25, K26, K27, K28, K29, \
     N30, N31, K32, K33, K34,                K35, K36, K37, N38, N39 \
) \
{{ layer.row0_left }}               {{ layer.row0_right }}  \
{{ layer.r1_l }}   K00  K01  K02  K03  K04                                  K05  K06  K07  K08  K09  {{ layer.r1_r }} \
{{ layer.r2_l }} K10  K11  K12  K13  K14                                  K15  K16  K17  K18  K19  {{ layer.r2_r }} \
{{ layer.r3_l }} K20  K21  K22  K23  K24  {{ layer.lie_k }}            {{ layer.rie_k }}  K25  K26  K27  K28  K29  {{ layer.r3_r }} \
                {{ layer.th_l }} K32  K33  K34                        K35  K36  K37  {{ layer.th_r }}

{% endfor %}
// ── behaviors ───────────────────────────────────────────────────────────
/ {
  behaviors {
    u_mt: u_mt {
      compatible = "zmk,behavior-hold-tap";
      #binding-cells = <2>;
      tapping-term-ms = <{{ behaviors.tap_term_ms }}>;
{% if behaviors.quick_tap_ms > 0 %}
      quick-tap-ms = <{{ behaviors.quick_tap_ms }}>;
{% endif %}
      flavor = "tap-preferred";
      bindings = <&kp>, <&kp>;
    };
    u_lt: u_lt {
      compatible = "zmk,behavior-hold-tap";
      #binding-cells = <2>;
      tapping-term-ms = <{{ behaviors.tap_term_ms }}>;
{% if behaviors.quick_tap_ms > 0 %}
      quick-tap-ms = <{{ behaviors.quick_tap_ms }}>;
{% endif %}
      flavor = "tap-preferred";
      bindings = <&mo>, <&kp>;
    };
{% for i in range(10) %}
    u_to_{{ i }}: u_to_{{ i }} {
      compatible = "zmk,behavior-tap-dance";
      #binding-cells = <0>;
      tapping-term-ms = <{{ behaviors.tap_term_ms }}>;
      bindings = <&none>, <&to {{ i }}>;
    };
{% endfor %}
  };

  // ── sensor bindings ────────────────────────────────────────────────
  sensors {
    compatible = "zmk,keymap-sensors";
    sensors = <&left_encoder &right_encoder>;
    triggers-per-rotation = <20>;
{% for layer in sensor_layers %}
    {{ layer.name }}_sensors: {{ layer.name }}_sensor_binding {
      layers = <{{ layer.index }}>;
      bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN &inc_dec_kp LEFT RIGHT>;
    };
{% endfor %}
  };

  // ── keymap ─────────────────────────────────────────────────────────
  keymap {
    compatible = "zmk,keymap";
{% for layer in layers %}
    {{ layer.name }}: {{ layer.name }} {
      display-name = "{{ layer.display }}";
      bindings = <SWITCHBOARD_MAP_{{ layer.name | upper }}({{ layer.inner_keys | join(", ") }})>;
{%- if not loop.last %}    };
{% else %}    };
{% endif %}
{% endfor %}
  };
};
